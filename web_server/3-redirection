#!/usr/bin/env bash
# Configure Nginx and redirect /redirect_me

apt-get -y update
apt-get -y install nginx

sed -i 's|try_files \$uri \$uri/ =404;|rewrite ^/redirect_me/?$ https://www.youtube.com/watch?v=QH2-TGUlwu4 permanent;\
        try_files $uri $uri/ =404;|' /etc/nginx/sites-available/default

service nginx restart
